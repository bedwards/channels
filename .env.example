# Google Cloud / Gemini API
GOOGLE_API_KEY=your_gemini_api_key_here

# YouTube Data API v3 (OAuth 2.0)
YOUTUBE_CLIENT_ID=your_youtube_client_id
YOUTUBE_CLIENT_SECRET=your_youtube_client_secret

# Substack (unofficial API)
SUBSTACK_EMAIL=your_substack_email
SUBSTACK_PASSWORD=your_substack_password

# ElevenLabs (optional, for future TTS)
ELEVENLABS_API_KEY=your_elevenlabs_api_key

# Content settings
CONTENT_DIR=data/content
DATABASE_PATH=data/channels.db

# Graphyard Database (studio host)
GRAPHYARD_DB_HOST=your_graphyard_host
GRAPHYARD_DB_PORT=5432
GRAPHYARD_DB_NAME=graphyard
GRAPHYARD_DB_USER=postgres
GRAPHYARD_DB_PASSWORD=postgres
